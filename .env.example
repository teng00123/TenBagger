# ──────────────────────────────────────────
# TenBagger 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ──────────────────────────────────────────

# ── API 服务配置 ──────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# ── 前端配置 ──────────────────────────────
# 前端访问的后端 API 地址
VITE_API_BASE_URL=http://localhost:8000

# ── 交易配置 ──────────────────────────────
# 初始资金（默认 10 万）
INITIAL_CAPITAL=100000
# 手续费率（默认万分之三）
COMMISSION_RATE=0.0003

# ── 数据源配置 ────────────────────────────
# mock: 使用模拟数据（开发/测试）
# real: 使用真实行情数据
DATA_SOURCE=mock

# ── 生产环境配置（部署时修改）─────────────
# 允许跨域的前端地址（生产环境必填，逗号分隔）
# ALLOWED_ORIGINS=https://your-frontend-domain.com
# SECRET_KEY=your-secret-key-here
